{
	"name": "cloudflare-openclaw-channel",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.18.0",
	"scripts": {
		"build": "pnpm -r --filter './packages/*' build && pnpm -r --filter './apps/*' build",
		"build:packages": "pnpm -r --filter './packages/*' build",
		"build:apps": "pnpm -r --filter './apps/*' build",
		"check": "npm run typecheck",
		"ci": "npm run typecheck && pnpm build && pnpm test",
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"demo:dev": "pnpm --filter @pandemicsyn/cf-do-channel-demo dev",
		"demo:preview": "pnpm --filter @pandemicsyn/cf-do-channel-demo preview",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"typecheck": "tsc -p tsconfig.json && tsc -p apps/web-demo/tsconfig.json",
		"test": "pnpm test:worker && pnpm test:web-demo",
		"test:web-demo": "vitest run -c vitest.web-demo.config.mts",
		"test:worker": "vitest run -c vitest.config.mts"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.13.5",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^25.5.0",
		"jsdom": "^26.1.0",
		"tsup": "^8.5.1",
		"typescript": "^5.5.2",
		"vitest": "^4.1.2",
		"wrangler": "^4.78.0"
	},
	"dependencies": {
		"zod": "^4.3.6"
	}
}
